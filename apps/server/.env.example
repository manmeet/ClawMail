GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8080/v1/auth/google/callback
HOST=127.0.0.1
PORT=8080
# Comma-separated allowed browser origins. Empty means allow all origins.
# Example: CORS_ORIGIN=https://clawmail-host.tailnet-name.ts.net
CORS_ORIGIN=
